<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DivideCuenta.DivideCuentaPage"
             Title="DivideCuenta">

    <ContentPage.Resources>
        <Color x:Key="colorFondo">#1E1B2E</Color>
        <Color x:Key="colorPrimario">#9D7FEA</Color>
        <Color x:Key="colorSecundario">#2D2645</Color>
    </ContentPage.Resources>

    <ScrollView BackgroundColor="{StaticResource colorFondo}">
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Monto de la cuenta (₡)"
                   TextColor="{StaticResource colorPrimario}"
                   FontAttributes="Bold"/>
            <Slider x:Name="sldMonto"
                    Minimum="0" Maximum="500000"
                    MinimumTrackColor="{StaticResource colorPrimario}"
                    MaximumTrackColor="{StaticResource colorSecundario}"
                    ThumbColor="{StaticResource colorPrimario}"
                    ValueChanged="Control_ValueChanged"/>
            <Label x:Name="lblMonto"
                   TextColor="{StaticResource colorPrimario}"
                   Text="Monto: ₡0"/>

            <Label Text="Número de personas"
                   TextColor="{StaticResource colorPrimario}"
                   FontAttributes="Bold"/>
            <Stepper x:Name="stpPersonas"
                     Minimum="1" Maximum="20" Increment="1"
                     ValueChanged="Control_ValueChanged"/>
            <Label x:Name="lblPersonas"
                   TextColor="{StaticResource colorPrimario}"
                   Text="Personas: 1"/>

            <Label Text="Propina (%)"
                   TextColor="{StaticResource colorPrimario}"
                   FontAttributes="Bold"/>
            <Slider x:Name="sldPropina"
                    Minimum="0" Maximum="30"
                    MinimumTrackColor="{StaticResource colorPrimario}"
                    MaximumTrackColor="{StaticResource colorSecundario}"
                    ThumbColor="{StaticResource colorPrimario}"
                    ValueChanged="Control_ValueChanged"/>
            <Label x:Name="lblPropina"
                   TextColor="{StaticResource colorPrimario}"
                   Text="Propina: 0%"/>

            <Frame BackgroundColor="{StaticResource colorSecundario}"
                   CornerRadius="10"
                   Margin="0,10,0,0">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="lblSubtotal"
                           TextColor="{StaticResource colorPrimario}"
                           Text="Subtotal: ₡0"/>
                    <Label x:Name="lblMontoPropina"
                           TextColor="{StaticResource colorPrimario}"
                           Text="Propina: ₡0"/>
                    <Label x:Name="lblTotal"
                           TextColor="{StaticResource colorPrimario}"
                           FontAttributes="Bold"
                           Text="Total: ₡0"/>
                    <Label x:Name="lblPorPersona"
                           TextColor="{StaticResource colorPrimario}"
                           FontAttributes="Bold"
                           Text="Por persona: ₡0"/>
                </VerticalStackLayout>
            </Frame>

            <Button x:Name="btnSorpresa"
                    Text="Propina Sorpresa"
                    BackgroundColor="{StaticResource colorPrimario}"
                    TextColor="{StaticResource colorSecundario}"
                    Clicked="btnSorpresa_Clicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>